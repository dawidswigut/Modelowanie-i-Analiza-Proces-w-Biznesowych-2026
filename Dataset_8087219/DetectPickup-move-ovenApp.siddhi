insert into EventMemoryTable;

@info(name="Detect-LowLevel-Pattern-6")
from every e1 = VGR_1Stream, e2 = VGR_1Stream[(e1.m1_speed==0 and e2.m1_speed==512)]
select "LowLevel-Pattern-6" as event, "Pickup-move-oven" as activity, "2023-03-20T11:08:14Z" as originalts
